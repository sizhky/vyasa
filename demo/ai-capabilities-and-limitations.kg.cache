    },
    "n36": {
      "chapter": "Practice",
      "description": "Do not trust or distrust the machine wholesale. Place the task on each continuum and respond to that shape.",
      "failure_family": "None",
      "group_id": null,
      "habit": "Calibrated trust",
      "id": "n36",
      "label": "Calibrated trust",
      "mitigation_family": "Verification",
      "property": "None",
      "role": "Habit",
      "section": "Practice"
    },
    "n37": {
      "chapter": "Practice",
      "description": "Names, dates, numbers, URLs, citations, quotes. Precision is where fluency most often impersonates truth.",
      "failure_family": "Fabrication",
      "group_id": null,
      "habit": "Verify specifics",
      "id": "n37",
      "label": "Verify specifics independently",
      "mitigation_family": "Verification",
      "property": "Next Token Prediction",
      "role": "Habit",
      "section": "Practice"
    },
    "n38": {
      "chapter": "Practice",
      "description": "If the model is thin, stale, or forgetful on your domain, bring the material yourself.",
      "failure_family": "Attention",
      "group_id": null,
      "habit": "Supply context",
      "id": "n38",
      "label": "Supply the missing knowledge and context",
      "mitigation_family": "Context",
      "property": "Working Memory",
      "role": "Habit",
      "section": "Practice"
    },
    "n39": {
      "chapter": "Practice",
      "description": "A machine can obey a surface instruction and still miss the win condition. Goal language closes that gap.",
      "failure_family": "Control",
      "group_id": null,
      "habit": "State goals",
      "id": "n39",
      "label": "State the goal, not just the format",
      "mitigation_family": "Control",
      "property": "Steerability",
      "role": "Habit",
      "section": "Practice"
    },
    "n4": {
      "chapter": "Training",
      "description": "Reads vast text and learns one thing: what token plausibly comes next.",
      "failure_family": "None",
      "group_id": null,
      "habit": "Understand the machine",
      "id": "n4",
      "label": "Pretraining",
      "mitigation_family": "None",
      "property": "Training",
      "role": "Mechanism",
      "section": "Training"
    },
    "n40": {
      "chapter": "Practice",
      "description": "Most bad outputs are not one property failing alone. The pair tells you which fix actually matters.",
      "failure_family": "Compound",
      "group_id": null,
      "habit": "Name the collision",
      "id": "n40",
      "label": "Diagnose property pairs",
      "mitigation_family": "Verification",
      "property": "None",
      "role": "Habit",
      "section": "Practice"
    },
    "n41": {
      "chapter": "Practice",
      "description": "Model quality moves; the structure remains. The point is not memorizing edge cases but seeing the machine through a stable lens.",
      "failure_family": "None",
      "group_id": null,
      "habit": "Think in properties",
      "id": "n41",
      "label": "Durable mental model",
      "mitigation_family": "None",
      "property": "None",
      "role": "Outcome",
      "section": "Practice"
    },
    "n5": {
      "chapter": "Training",
      "description": "The raw system after pretraining. Fluent continuation machine, not yet an assistant.",
      "failure_family": "None",
      "group_id": null,
      "habit": "Calibrated trust",
      "id": "n5",
      "label": "Document completer",
      "mitigation_family": "None",
      "property": "Next Token Prediction",
      "role": "Outcome",
      "section": "Training"
    },
    "n6": {
      "chapter": "Training",
      "description": "Human preference shaping turns completion into assistant behavior: answer helpfully, decline harmful asks, stay within norms.",
      "failure_family": "None",
      "group_id": null,
      "habit": "Understand the machine",
      "id": "n6",
      "label": "Fine-tuning",
      "mitigation_family": "None",
      "property": "Training",
      "role": "Mechanism",
      "section": "Training"
    },
    "n7": {
      "chapter": "Training",
      "description": "The interaction layer people meet. Useful, polite, often cooperative, never free of the mechanism beneath it.",
      "failure_family": "None",
      "group_id": null,
      "habit": "State the goal",
      "id": "n7",
      "label": "Helpful assistant",
      "mitigation_family": "None",
      "property": "Steerability",
      "role": "Outcome",
      "section": "Training"
    },
    "n8": {
      "chapter": "Fingerprints",
      "description": "The model leans toward validating the user's frame unless asked, or forced, to disagree.",
      "failure_family": "Character",
      "group_id": null,
      "habit": "Invite pushback",
      "id": "n8",
      "label": "Sycophancy",
      "mitigation_family": "Control",
      "property": "Training",
      "role": "Constraint",
      "section": "Fingerprints"
    },
    "n9": {
      "chapter": "Fingerprints",
      "description": "Left alone, the assistant often gives more than the task strictly needs.",
      "failure_family": "Character",
      "group_id": null,
      "habit": "Constrain format",
      "id": "n9",
      "label": "Verbosity default",
      "mitigation_family": "Control",
      "property": "Training",
      "role": "Constraint",
      "section": "Fingerprints"
    }
  },
