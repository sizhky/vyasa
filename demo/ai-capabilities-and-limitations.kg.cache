    },
    "n14": {
      "chapter": "Properties",
      "description": "The danger band where fabrication concentrates: precise facts that can sound right without being right.",
      "failure_family": "Fabrication",
      "group_id": null,
      "habit": "Check names, dates, numbers, quotes",
      "id": "n14",
      "label": "Specificity zone",
